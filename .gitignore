# ==========================================
# 🐍 Python and Local Environment Isolation
# ==========================================
# Exclude the local virtual environment folder entirely
venv/
.venv/
env/

# Ignore Python compilation caches (keeps git logs clean)
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/

# ==========================================
# 🗂️ Local Mock Data & Script Outputs
# ==========================================
# # Prevent mock source CSVs or generated pipeline run exports 
# # from cluttering your repository history
# *.csv
# *.xlsx
# *.json
!/rebate_transformation_layer/seeds/*.csv  # <-- EXCEPTION: Explicitly allow dbt seed files!

# Ignore local execution log files generated by python scripts
*.log

# ==========================================
# ❄️ dbt Transformation Layer Operational Artifacts
# ==========================================
# Logs generated when you run dbt commands
rebate_transformation_layer/logs/
rebate_transformation_layer/dbt_logs/

# The compile target folder (where dbt outputs compiled SQL behind the scenes)
rebate_transformation_layer/target/

# The packages folder (if you install external dbt packages later)
rebate_transformation_layer/dbt_packages/
rebate_transformation_layer/dbt_modules/

# ==========================================
# 💻 Operating System Clutter
# ==========================================
.DS_Store
Thumbs.db
.idea/
.vscode/